# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=your-32-char-minimum-secret-key-here

# HiveMQ Cloud
HIVEMQ_HOST=your-broker.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=your_mqtt_username
HIVEMQ_PASSWORD=your_mqtt_password

# Server
PORT=3000
NODE_ENV=development